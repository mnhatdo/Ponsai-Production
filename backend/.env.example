# Environment
NODE_ENV=development

# Server
PORT=3000
HOST=localhost

# Database
MONGODB_URI=mongodb://localhost:27017/furni
MONGODB_TEST_URI=mongodb://localhost:27017/furni

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# CORS
CORS_ORIGIN=http://localhost:4200

# API
API_VERSION=v1
API_PREFIX=/api

# Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# MOMO Payment Gateway (Sandbox)
MOMO_PARTNER_CODE=MOMOBKUN20180529
MOMO_ACCESS_KEY=klm05TvNBzhg7h7j
MOMO_SECRET_KEY=at67qH6mk8w5Y1nAyMoYKMWACiEi2bsa
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=http://localhost:4200/payment/momo/callback
MOMO_IPN_URL=http://localhost:3000/api/v1/payment/momo/ipn

# SMTP Email
# secure=false for port 587 (STARTTLS)
# secure=true for port 465 (SSL/TLS)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password-or-smtp-password
SMTP_FROM=noreply@ponsai.com

# Optional fallback over HTTPS without custom domain (Gmail API)
# 1) Create OAuth client credentials in Google Cloud
# 2) Generate refresh token with OAuth Playground
GMAIL_API_CLIENT_ID=your-google-oauth-client-id
GMAIL_API_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_API_REFRESH_TOKEN=your-google-refresh-token
GMAIL_API_SENDER=your-gmail-address@gmail.com

# Optional fallback email provider over HTTPS (recommended in production)
# Create API key at https://resend.com and set a verified sender/domain.
RESEND_API_KEY=your-resend-api-key
