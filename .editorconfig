# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org

root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.json]
indent_size = 2

[*.{ts,js}]
indent_size = 2

[*.html]
indent_size = 2

[*.css, *.scss]
indent_size = 2

[Makefile]
indent_style = tab
